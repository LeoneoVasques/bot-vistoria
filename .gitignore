uploads/images/*
!uploads/images/.gitkeep
output/*
!output/.gitkeep

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Sistema Operacional
.DS_Store
Thumbs.db
Desktop.ini
