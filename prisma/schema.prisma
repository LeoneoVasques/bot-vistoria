generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InspectionStatus {
  EM_ANDAMENTO
  AGUARDANDO_APROVACAO
  CONCLUIDO
  CANCELADO
}

enum SubscriberStatus {
  ACTIVE
  PENDING
  SUSPENDED
  CANCELED
}

model Subscriber {
  id                     String               @id @default(uuid())
  name                   String
  phone                  String               @unique
  status                 SubscriberStatus     @default(ACTIVE)
  plan                   String               @default("PRO")
  maxInspectionsPerMonth Int                  @default(100)
  inspectionsCount       Int                  @default(0)
  expiresAt              DateTime?
  templates              SubscriberTemplate[]
  inspections            Inspection[]
  signatureUrl           String?
  signaturePath          String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@map("subscribers")
}

model SubscriberTemplate {
  id           String     @id @default(uuid())
  subscriberId String
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  name         String     @default("Ficha Principal")
  pdfUrl       String
  pdfPath      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("subscriber_templates")
}

model Inspection {
  id              String           @id @default(uuid())
  plate           String           @unique
  userPhone       String
  subscriberId    String?
  subscriber      Subscriber?      @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  status          InspectionStatus @default(EM_ANDAMENTO)
  transcriptions  String[]
  reportData      Json?
  pdfPath         String?
  photos          InspectionPhoto[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("inspections")
}

model InspectionPhoto {
  id           String     @id @default(uuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  filePath     String
  createdAt    DateTime   @default(now())

  @@map("inspection_photos")
}
