    "@hapi/boom": "^10.0.1",
    "@prisma/client": "^5.19.1",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bullmq": "^5.81.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fluent-ffmpeg": "^2.1.3",
    "handlebars": "^4.7.8",
