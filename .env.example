# Server Config
PORT=3000
HOST=0.0.0.0

# Redis Config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL / Prisma Config
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vistoriabot?schema=public"

# OpenAI API Key
OPENAI_API_KEY="sk-proj-your-openai-key"

# Controle de Acesso/Assinaturas de Localizadores (false = modo livre/desenvolvimento; true = exige assinatura ativa)
CHECK_SUBSCRIBER_ACCESS=false

# Cloudflare R2 / AWS S3 Config (Opcional - Ativa upload na nuvem)
R2_ACCOUNT_ID="seu_account_id_cloudflare"
R2_ACCESS_KEY_ID="sua_access_key"
R2_SECRET_ACCESS_KEY="sua_secret_key"
R2_BUCKET_NAME="vistoriabot-midias"
R2_PUBLIC_URL="https://midias.seudominio.com.br"

# Segurança da API Rest
ADMIN_API_KEY="sua_chave_secreta_admin_aqui"

